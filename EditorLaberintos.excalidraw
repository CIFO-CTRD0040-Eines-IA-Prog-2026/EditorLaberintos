      ],
      "updated": 1783675349220,
      "link": null,
      "locked": false,
      "text": "Parrilla que define el laberinto actual.\nLas casillas negras son paredes, las\nblancas suelo. Al clickar con el boton\nizquierdo sobre ellas se cambiará entre\npared y suelo",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Parrilla que define el laberinto actual.\nLas casillas negras son paredes, las\nblancas suelo. Al clickar con el boton\nizquierdo sobre ellas se cambiará entre\npared y suelo",
      "autoResize": true,
      "lineHeight": 1.25
    },
