          "type": "arrow"
        }
      ],
      "updated": 1783675349220,
      "link": null,
      "locked": false,
      "text": "Indicador de la posición y orientación\nde la cámara. Al pulsar con el botón derecho\nen una casilla suelo se asignará a ella el\nmarcador",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Indicador de la posición y orientación\nde la cámara. Al pulsar con el botón derecho\nen una casilla suelo se asignará a ella el\nmarcador",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "HJBfCfKwVCSbF0Lo_JRyM",
      "type": "text",
      "x": 140.95475222420282,
      "y": 874.9742063044232,
      "width": 429.3666687011719,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2o",
      "roundness": null,
      "seed": 1811882732,
      "version": 652,
      "versionNonce": 463626196,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "sT2exYotNuIuAaGvvMerd",
          "type": "arrow"
        }
      ],
      "updated": 1783676041306,
      "link": null,
      "locked": false,
      "text": "Ventana de navegación que muestra una\nrepresentación 3D del laberinto actual\ndesde al posición y orientación de la cámara.\nSi tiene el foco, podrá navegarse con las\nteclas de cursor:\n* Avanzar/ retroceder con ariba/abajo una\ncasilla en la orientación actual.\n* Girar 90º con izquierda/derecha",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ventana de navegación que muestra una\nrepresentación 3D del laberinto actual\ndesde al posición y orientación de la cámara.\nSi tiene el foco, podrá navegarse con las\nteclas de cursor:\n* Avanzar/ retroceder con ariba/abajo una\ncasilla en la orientación actual.\n* Girar 90º con izquierda/derecha",
      "autoResize": true,
      "lineHeight": 1.25
    },
